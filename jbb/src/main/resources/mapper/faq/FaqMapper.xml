<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.naver.jbb.dao.FaqMapper">

    <!-- FAQ 목록 조회 -->
    <select id="user-faqlist" parameterType="com.naver.jbb.domain.SearchCondition" resultType="com.naver.jbb.domain.FaqDTO">
        SELECT * FROM faq
        WHERE true
        <choose>
            <when test='option=="Q"'>
                AND f_question LIKE concat('%', #{keyword}, '%')
            </when>
        </choose>
        ORDER BY fno DESC
        LIMIT #{offset}, #{pageSize}
    </select>
    <select id="faqCnt" parameterType="com.naver.jbb.domain.SearchCondition" resultType="int">
        SELECT COUNT(*)
        FROM faq
        WHERE true
        <choose>
            <when test='option=="Q"'>
                AND f_question LIKE concat('%', #{keyword}, '%')
            </when>
        </choose>
    </select>
</mapper>