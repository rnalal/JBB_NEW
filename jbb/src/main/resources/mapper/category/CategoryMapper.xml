<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.naver.jbb.dao.CategoryMapper">

    <!-- 모든 카테고리 리스트 불러오기 (대분류+중분류) -->
    <select id="getAllCategories" resultType="com.naver.jbb.domain.CategoryDTO">
        SELECT bc_code, bc_name, bc_code_ref_mn
        FROM category
    </select>

    <!-- 중분류 조회 -->
    <select id="getSubCategories" resultType="com.naver.jbb.domain.CategoryDTO" parameterType="int">
        SELECT bc_code, bc_name, bc_code_ref_mn
        FROM category
        WHERE bc_code_ref_mn = #{mainCategory}
    </select>

</mapper>